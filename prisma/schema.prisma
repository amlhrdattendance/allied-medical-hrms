generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model CompanyProfile {
  id               String   @id @default(uuid())
  companyName      String
  dateEstablished  String?
  cinLpin          String?
  tan              String?
  website          String?
  
  address1         String?
  address2         String?
  address3         String?
  phone1           String?
  phone2           String?
  shortName        String?
  
  pfEnabled        Boolean  @default(false)
  esiEnabled       Boolean  @default(false)
  ptEnabled        Boolean  @default(false)
  tdsEnabled       Boolean  @default(false)
  lwfEnabled       Boolean  @default(false)

  updatedAt        DateTime @updatedAt
  createdAt        DateTime @default(now())
}

model Branch {
  id               String   @id @default(uuid())
  branchName       String
  employees        EmployeeMaster[]
}

model Department {
  id               String   @id @default(uuid())
  deptName         String
  employees        EmployeeMaster[]
}

model EmployeeMaster {
  id               String   @id @default(uuid())
  employeeCode     String   @unique
  firstName        String
  lastName         String?
  email            String?  @unique
  phone            String?
  gender           String?
  dob              String?

  // Dates
  dateOfJoining    String?
  probationEnd     String?
  confirmationDate String?

  // Statutory
  panNumber        String?
  uanNumber        String?
  bankAccount      String?

  // Relations
  branchId         String?
  branch           Branch?  @relation(fields: [branchId], references: [id])
  
  departmentId     String?
  department       Department? @relation(fields: [departmentId], references: [id])

  updatedAt        DateTime @updatedAt
  createdAt        DateTime @default(now())
}
