generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  role      String   @default("Employee") // Admin, HR, Manager, Employee
  employeeId String? @unique
  employee  EmployeeMaster? @relation(fields: [employeeId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CompanyProfile {
  id               String   @id @default(uuid())
  companyName      String
  logo             String?
  dateEstablished  String?
  cinLpin          String?
  tan              String?
  website          String?
  
  address1         String?
  address2         String?
  address3         String?
  phone1           String?
  phone2           String?
  shortName        String?
  
  pfEnabled        Boolean  @default(false)
  esiEnabled       Boolean  @default(false)
  ptEnabled        Boolean  @default(false)
  tdsEnabled       Boolean  @default(false)
  lwfEnabled       Boolean  @default(false)

  updatedAt        DateTime @updatedAt
  createdAt        DateTime @default(now())
}

model Branch {
  id               String   @id @default(uuid())
  branchName       String
  employees        EmployeeMaster[]
}

model Department {
  id               String   @id @default(uuid())
  deptName         String
  employees        EmployeeMaster[]
}

model Designation {
  id        String   @id @default(uuid())
  title     String
  employees EmployeeMaster[]
}

model EmployeeMaster {
  id               String   @id @default(uuid())
  employeeCode     String   @unique
  firstName        String
  lastName         String?
  email            String?  @unique
  phone            String?
  gender           String?
  dob              String?

  // Classification
  branchId         String?
  branch           Branch?  @relation(fields: [branchId], references: [id])
  departmentId     String?
  department       Department? @relation(fields: [departmentId], references: [id])
  designationId    String?
  designation      Designation? @relation(fields: [designationId], references: [id])

  // Employment Dates
  dateOfJoining    String?
  probationEnd     String?
  confirmationDate String?

  // Statutory
  panNumber        String?
  uanNumber        String?
  bankAccount      String?
  ifscCode         String?
  esiNumber        String?

  // Features
  user             User?
  attendance       Attendance[]
  leaveRequests    LeaveRequest[]
  salaryRates      SalaryRate[]
  documents        Document[]

  updatedAt        DateTime @updatedAt
  createdAt        DateTime @default(now())
}

model Attendance {
  id           String   @id @default(uuid())
  employeeId   String
  employee     EmployeeMaster @relation(fields: [employeeId], references: [id])
  date         String   // YYYY-MM-DD
  clockIn      DateTime?
  clockOut     DateTime?
  isLate       Boolean  @default(false)
  isEarlyExit  Boolean  @default(false)
  locationIn   String?
  locationOut  String?
  ipAddress    String?
  status       String   @default("Present") // Present, Absent, Half-Day, On-Leave
  remarks      String?
}

model LeaveRequest {
  id           String   @id @default(uuid())
  employeeId   String
  employee     EmployeeMaster @relation(fields: [employeeId], references: [id])
  leaveType    String   // CL, EL, SL, LWP
  startDate    String
  endDate      String
  totalDays    Float
  reason       String?
  status       String   @default("Pending") // Pending, Approved, Rejected
  appliedAt    DateTime @default(now())
  approverId   String?
}

model SalaryRate {
  id            String   @id @default(uuid())
  employeeId    String
  employee      EmployeeMaster @relation(fields: [employeeId], references: [id])
  componentName String   // Basic, HRA, etc.
  amount        Float
  frequency     String   @default("Monthly")
  effectiveFrom String
}

model Document {
  id            String   @id @default(uuid())
  employeeId    String
  employee      EmployeeMaster @relation(fields: [employeeId], references: [id])
  documentName  String   // PAN Card, Aadhar Card, etc.
  documentType  String
  fileUrl       String
  uploadedAt    DateTime @default(now())
}
